{
  "name": "crawlerdesafio",
  "version": "1.0.0",
  "description": "Web scraper para books.toscrape.com — desafio técnico",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "lint": "eslint src",
    "test": "jest",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:studio": "DATABASE_URL=postgresql://crawler:crawler@localhost:5432/crawlerdb?schema=public prisma studio",
    "postinstall": "prisma generate"
  },
  "keywords": [
    "scraping",
    "playwright",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "dotenv": "^17.2.3",
    "openai": "^6.8.1",
    "pg": "^8.16.0",
    "playwright": "^1.60.0",
    "prisma": "^7.0.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4"
  }
}
